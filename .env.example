# ─────────────────────────────────────────────────────────────────
# GitHub Cloud Connector — Environment Variables
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Required: GitHub Personal Access Token ───────────────────────
# Create at: https://github.com/settings/tokens
# Scopes needed: repo, read:user, read:org
GITHUB_TOKEN=ghp_your_token_here

# ── Optional: OAuth 2.0 ──────────────────────────
# Create a GitHub OAuth App at: https://github.com/settings/applications/new
# Set Authorization callback URL to: http://localhost:8000/auth/oauth/callback
GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here
GITHUB_REDIRECT_URI=http://localhost:8000/auth/oauth/callback

# ── App Settings ─────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development
